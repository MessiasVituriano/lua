APP_NAME="LUA PetShop"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://SEU_IP_AQUI

# Sanctum/Session: ajustar para o IP (ou depois o dominio) sem protocolo.
# Sem isso, auth via SPA (cookie) nao funciona.
SANCTUM_STATEFUL_DOMAINS=SEU_IP_AQUI
SESSION_DOMAIN=SEU_IP_AQUI

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=lua
DB_USERNAME=lua_user
# IMPORTANTE: Gere uma senha forte. Ex: openssl rand -base64 32
DB_PASSWORD=TROCAR_POR_SENHA_FORTE

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@lua.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
